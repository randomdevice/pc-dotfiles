{
    // "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    // "height": 30, // Waybar height (to be removed for auto height)
    "margin": "20 20 0 20",
    // "width": 1280, // Waybar width
    // Choose the order of the modules
    "modules-left": ["custom/pacman", "cpu", "custom/mem", "custom/llm", "hyprland/workspaces", ],
    "modules-center": ["clock"],
    "modules-right": [ "custom/weather", "pulseaudio",  "tray"],


    //***************************
    //*  Modules configuration  *
    //***************************

    "hyprland/workspaces": {
 	    "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
	       "active": "ґ░Жж",
           "default": "ґ░Жз",
	    },     
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
        }
    },

    "hyprland/language": {
        "format": "{} яаЛ",
     	"min-length": 5,
	    "tooltip": false
    },

    "keyboard-state": {
        //"numlock": true,
        "capslock": true,
        "format": "{name} {icon} ",
        "format-icons": {
            "locked": "яАг ",
            "unlocked": "яВЬ"
        },
    },

    "custom/pacman": {
        "format": "яМГ",
        "on-click": "kitty sh -c 'pacseek -ui'", // list packages
        "tooltip": false,
    },

    "custom/llm": {
        "format": "ґ▒ЬЩ",
        "on-click": "firefoxpwa site launch 01J6Q0GV2DN198AQZT0JWMFRQX",
        "tooltip": false,
    },

    "custom/mail": {
        "format": "{} яЮк",
        "exec": "$HOME/.config/waybar/scripts/checkgmail.py",
        "interval": 120,
        "on-click": "google-chrome-stable https://mail.google.com/mail/u/0/#inbox ; pkill -SIGRTMIN+9 waybar",
        "signal": 9,
        "tooltip": false,
    },

    "hyprland/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },

    "clock": {
        "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%a, %d %b, %I:%M %p}"
    },

    "custom/weather": {
        "format": "{}┬░",
        "tooltip": true,
        "interval": 3600,
        "exec": "wttrbar --location 'Trenton'",
        "return-type": "json"
    },

    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "reverse-scrolling": 1,
        "format": "{volume}% {icon}  {format_source}",
        "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
        "format-bluetooth-muted": "{volume}% ґ░ЭЯ {icon}яКФ {format_source}",
        "format-muted": "{volume}% ґ░ЭЯ {format_source}",
        "format-source": "{volume}% яД░",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яАе",
            "headset": "яЯН",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАе", "яАе", "яАе"]
        },
        "on-click": "pavucontrol",
        "min-length": 10,
    },

    "custom/mem": {
        "format": "{} яЛЫ ",
        "interval": 3,
        "exec": "free -h | awk '/Mem:/{printf $3}'",
        "on-click": "kitty sh -c 'btop'",
        "tooltip": false,
    },

    "cpu": {
         "interval": 1,
         "format": "{usage}% {icon}",
         "format-icons": [
              "<span color='#69ff94'>тЦБ</span>", // green
              "<span color='#2aa9ff'>тЦВ</span>", // blue
              "<span color='#f8f8f2'>тЦГ</span>", // white
              "<span color='#f8f8f2'>тЦД</span>", // white
              "<span color='#ffffa5'>тЦЕ</span>", // yellow
              "<span color='#ffffa5'>тЦЖ</span>", // yellow
              "<span color='#ff9977'>тЦЗ</span>", // orange
              "<span color='#dd532e'>тЦИ</span>"  // red
         ]
    },

    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["яЛЛ", "яЛК", "яЛЙ", "яЛИ", "яЛЗ"],
        "tooltip": false,
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{percent}% {icon}",
        "format-icons": ["яЧЩ","яЧЪ","яЧЫ","яЧЬ", "яЧЭ", "яЧЮ", "яЧЯ"],
        "min-length": 7,
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% яЦГ",
        "format-plugged": "{capacity}% яЗж",
        "format-alt": "{time} {icon}",
        "format-icons": ["яХ╣", "яХ║", "яХ╗", "яХ╗", "яХ╜", "яХ╛", "яХ┐", "яЦА", "яЦБ", "яХ╕"],
	"on-update": "$HOME/.config/waybar/scripts/check_battery.sh",
    },

    "tray": {
        "icon-size": 16,
        "spacing": 8
    },
}
