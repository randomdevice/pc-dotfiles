{
    // "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    // "height": 30, // Waybar height (to be removed for auto height)
    "margin": "20 20 0 20",
    // "width": 1280, // Waybar width
    // Choose the order of the modules
    "modules-left": ["cpu", "custom/mem", "hyprland/workspaces", ],
    "modules-center": ["clock"],
    "modules-right": [ "custom/weather", "pulseaudio",  "tray"],


    //***************************
    //*  Modules configuration  *
    //***************************

    "hyprland/workspaces": {
 	"format": "{icon}",
        "format-icons": {
	   "active": "­ƒö▓",
           "default": "­ƒö│",
	},     
        "disable-scroll": true,
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
        }
    },

    "hyprland/language": {
        "format": "{} ´áï",
	"min-length": 5,
	"tooltip": false
    },

    "keyboard-state": {
        //"numlock": true,
        "capslock": true,
        "format": "{name} {icon} ",
        "format-icons": {
            "locked": "´Çú ",
            "unlocked": "´é£"
        },
    },

    "custom/pacman": {
        "format": "{} ´îâ",
        "interval": 3600,                     			// every hour
        "exec": "(checkupdates;pacman -Qm | aur vercmp) | wc -l",	// # of updates
        "exec-if": "exit 0",                  			// always run; consider advanced run conditions
        "on-click": "kitty sh -c 'yay; echo Done - Press enter to exit; read'; pkill -SIGRTMIN+8 waybar", // update system
        "signal": 8,
        "tooltip": false,
    },

    "custom/mail": {
        "format": "{} ´×¬",
        "exec": "$HOME/.config/waybar/scripts/checkgmail.py",
        "interval": 120,
        "on-click": "google-chrome-stable https://mail.google.com/mail/u/0/#inbox ; pkill -SIGRTMIN+9 waybar",
        "signal": 9,
        "tooltip": false,
    },

    "hyprland/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },

    "clock": {
        "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%a, %d %b, %I:%M %p}"
    },

    "custom/weather": {
        "format": "{}┬░",
        "tooltip": true,
        "interval": 3600,
        "exec": "wttrbar --location 'Trenton'",
        "return-type": "json"
    },

    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "reverse-scrolling": 1,
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}´èö {format_source}",
        "format-bluetooth-muted": "´ƒÅ {icon}´èö {format_source}",
        "format-muted": "´¬Ç {format_source}",
        "format-source": "{volume}% ´ä░",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´ÇÑ",
            "hands-free": "´ú│",
            "headset": "´ƒì",
            "phone": "´éò",
            "portable": "´éò",
            "car": "´å╣",
            "default": ["´®¥", "´®┐", "´®¢"]
        },
        "on-click": "pavucontrol",
        "min-length": 13,
    },

    "custom/mem": {
        "format": "{} ´ïø ",
        "interval": 3,
        "exec": "free -h | awk '/Mem:/{printf $3}'",
        "tooltip": false,
    },

    "cpu": {
         "interval": 1,
         "format": "{usage}% {icon}",
         "format-icons": [
              "<span color='#69ff94'>Ôûü</span>", // green
              "<span color='#2aa9ff'>Ôûé</span>", // blue
              "<span color='#f8f8f2'>Ôûâ</span>", // white
              "<span color='#f8f8f2'>Ôûä</span>", // white
              "<span color='#ffffa5'>Ôûà</span>", // yellow
              "<span color='#ffffa5'>Ôûå</span>", // yellow
              "<span color='#ff9977'>Ôûç</span>", // orange
              "<span color='#dd532e'>Ôûê</span>"  // red
         ]
    },

    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["´ïï", "´ïè", "´ïë", "´ïê", "´ïç"],
        "tooltip": false,
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{percent}% {icon}",
        "format-icons": ["´ùÖ","´ùÜ","´ùø","´ù£", "´ùØ", "´ù×", "´ùƒ"],
        "min-length": 7,
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ´ûâ",
        "format-plugged": "{capacity}% ´çª",
        "format-alt": "{time} {icon}",
        "format-icons": ["´ò╣", "´ò║", "´ò╗", "´ò╗", "´ò¢", "´ò¥", "´ò┐", "´ûÇ", "´ûü", "´ò©"],
	"on-update": "$HOME/.config/waybar/scripts/check_battery.sh",
    },

    "tray": {
        "icon-size": 16,
        "spacing": 8
    },
}
